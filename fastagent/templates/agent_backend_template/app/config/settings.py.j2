from dataclasses import dataclass
import os

from dotenv import load_dotenv

load_dotenv()


@dataclass
class Settings:
    app_name: str = os.getenv("APP_NAME", "{{ project_name }}")
    environment: str = os.getenv("ENVIRONMENT", "development")
    agent_type: str = os.getenv("AGENT_TYPE", "{{ project_type }}")
    llm_provider: str = os.getenv("LLM_PROVIDER", "{{ llm_provider }}")
    router_mode: str = os.getenv("ROUTER_MODE", "balanced")
    router_providers: str = os.getenv("ROUTER_PROVIDERS", "OpenAI,Anthropic,Google DeepMind,Meta AI")
    vector_db: str = os.getenv("VECTOR_DB", "{{ vector_db }}")
    memory_type: str = os.getenv("MEMORY_TYPE", "{{ memory_type }}")
    tracing_backend: str = os.getenv("TRACING_BACKEND", "{{ tracing }}")
    evaluation_enabled: bool = os.getenv("EVALUATION_ENABLED", "{{ evaluation_enabled_literal }}").lower() == "true"
    architect_provider: str = os.getenv("ARCHITECT_PROVIDER", "{{ architect_provider }}")
    architect_model: str = os.getenv("ARCHITECT_MODEL", "{{ architect_model }}")
    architect_openai_mode: str = os.getenv("ARCHITECT_OPENAI_MODE", "{{ architect_openai_mode }}")
    architect_cache_enabled: bool = os.getenv("ARCHITECT_CACHE_ENABLED", "{{ architect_cache_enabled_literal }}").lower() == "true"
    architect_cache_ttl: int = int(os.getenv("ARCHITECT_CACHE_TTL", "{{ architect_cache_ttl_seconds }}"))
    architect_timeout: int = int(os.getenv("ARCHITECT_TIMEOUT", "20"))
    architect_retries: int = int(os.getenv("ARCHITECT_RETRIES", "2"))
    architect_backoff: float = float(os.getenv("ARCHITECT_BACKOFF", "0.5"))


settings = Settings()
